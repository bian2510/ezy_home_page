# Public runtime configuration consumed by Vite. Variables MUST be prefixed
# with VITE_ to be exposed to the client bundle. Do not put secrets here —
# every value ships to the browser.
VITE_API_BASE_URL=https://api.ezyhome.local
VITE_SITE_NAME=EzyHome

# VITE_WHATSAPP_NUMBER — número de WhatsApp de EzyHome para el checkout.
# Lo usa el botón "Comprar por WhatsApp" para construir la URL wa.me/{NUMERO}.
# Formato: SOLO DÍGITOS. Sin "+", sin espacios, sin guiones, sin paréntesis.
# Debe incluir el código de país (54 para Argentina) y, para móviles
# argentinos, el "9" antes del código de área.
# Ejemplo (móvil de CABA): 5491112345678
#   54  → código de país (Argentina)
#   9   → prefijo móvil
#   11  → código de área (CABA)
#   12345678 → número de abonado
VITE_WHATSAPP_NUMBER=
